{
  "name": "claudemon",
  "version": "1.4.2",
  "description": "Widget de desktop: consumo do Claude + Pokémon 8-bit dançando",
  "main": "main.js",
  "author": "Manowz",
  "license": "MIT",
  "repository": "github:manowz/claudemon",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "br.manowz.claudemon",
    "productName": "Claudemon",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable.${ext}"
    },
    "mac": {
      "icon": "assets/icon-mac.png",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "renderer/**",
      "assets/**"
    ]
  }
}
